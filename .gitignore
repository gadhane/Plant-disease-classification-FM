# Model Checkpoints — large binary files, use Git LFS or DVC instead
# =============================================================================
checkpoints/
finetune_checkpoints/
*.pt
*.pth
*.ckpt
*.pkl
*.pickle
*.h5
*.hdf5
*.safetensors
*.bin

# =============================================================================
# XAI / GradCAM outputs and others
# =============================================================================
xai/
Fine-tune/
# =============================================================================
# Jupyter Notebooks checkpoints
# =============================================================================
.ipynb_checkpoints/
*.ipynb

